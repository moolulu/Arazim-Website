---
const { data } = Astro.props;
---

<section class={`station align-${data.align}`}>
  <div class="glass-card">
    <h2>{data.title}</h2>
    <p>{data.text}</p>
    
    {/* Check if the links array exists and has items, then loop through it */}
    {data.links && data.links.length > 0 && (
      <div class="link-container">
        {data.links.map((link) => (
          <a href={link.url} class="station-link">{link.text}</a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .station {
    height: 100dvh;
    width: 100%;
    scroll-snap-align: start;
    display: flex;
    align-items: center;
    padding: 0 10%;
    box-sizing: border-box;
    position: relative;
    z-index: 10;
  }

  /* RTL Alignment Logic */
  .align-start { justify-content: flex-start; } /* Anchors to Right */
  .align-end { justify-content: flex-end; }     /* Anchors to Left */
  .align-center { justify-content: center; text-align: center; }

  /* The Glassmorphism Card */
  .glass-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 16px;
    padding: 3rem;
    max-width: 500px;
    color: white;
  }

  .station-id {
    font-size: 0.9rem;
    letter-spacing: 2px;
    opacity: 0.7;
    font-weight: 600;
  }

  h2 {
    font-size: 3.5rem;
    margin: 0.5rem 0 1rem 0;
    line-height: 1.1;
    font-weight: 800;
  }

  p {
    font-size: 1.2rem;
    line-height: 1.6;
    opacity: 0.9;
    margin-bottom: 1.5rem; 
  }

  /* Container to manage multiple buttons */
  .link-container {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap; 
    justify-content: center; /* Centers the buttons inside the card */
    margin-top: 1.5rem; /* Optional: adds a little space above the buttons */
  }

  /* Glassmorphism Link Styles */
  .station-link {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    color: white;
    text-decoration: none;
    font-weight: 600;
    letter-spacing: 1px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 8px;
    transition: all 0.3s ease;
  }

  .station-link:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.5);
    transform: translateY(-2px);
  }

  /* Mobile Overrides */
  @media (max-width: 768px) {
    .station {
      padding: 0 5%;
      justify-content: center; 
    }

    .glass-card {
      padding: 2rem;
      text-align: right;
    }

    h2 { font-size: 2.5rem; }
  }
</style>