---
const { data } = Astro.props;
---

<section class={`station align-${data.align}`}>
  <div class="glass-card">
    <h2>{data.title}</h2>
    
    {/* set:html renders the string as actual HTML, allowing <p> tags and math blocks */}
    <div class="rich-text-container" set:html={data.text}></div>
  </div>
</section>

<script is:inline src="https://polyfill.io/v3/polyfill.min.js?features=es6"></script>
<script is:inline id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>

<style>
  .station {
    height: 100dvh;
    width: 100%;
    scroll-snap-align: start;
    display: flex;
    align-items: center;
    padding: 0 10%;
    box-sizing: border-box;
    position: relative;
    z-index: 10;
  }

  .align-start { justify-content: flex-start; } 
  .align-end { justify-content: flex-end; }     
  .align-center { justify-content: center; text-align: center; }

  .glass-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 16px;
    padding: 3rem;
    max-width: 600px; 
    color: white;
  }

  .station-id {
    font-size: 0.9rem;
    letter-spacing: 2px;
    opacity: 0.7;
    font-weight: 600;
  }

  h2 {
    font-size: 3.5rem;
    margin: 0.5rem 0 1rem 0;
    line-height: 1.1;
    font-weight: 800;
  }

  /* --- INJECTED HTML STYLES --- */
  /* We must use :global() because this HTML is injected at runtime via set:html */
  
  .rich-text-container :global(p) {
    font-size: 1.2rem;
    line-height: 1.6;
    opacity: 0.9;
    margin-bottom: 1rem;
  }

  .rich-text-container :global(.math-block) {
    direction: ltr; /* CRITICAL: Forces standalone math blocks to render LTR */
    background: rgba(0, 0, 0, 0.25);
    padding: 1.5rem;
    border-radius: 8px;
    margin: 1.5rem 0;
    text-align: center;
    overflow-x: auto;
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 1.3rem;
  }

  @media (max-width: 768px) {
    .station {
      padding: 0 5%;
      justify-content: center; 
    }
    .glass-card {
      padding: 2rem;
      text-align: right; 
    }
    h2 { font-size: 2.5rem; }
    .rich-text-container :global(.math-block) {
      font-size: 1.1rem;
      padding: 1rem;
    }
  }
</style>