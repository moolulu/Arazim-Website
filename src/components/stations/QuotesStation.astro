---
const { data } = Astro.props;
const quotes = data.quotes || [];
---

<section class={`station align-${data.align || 'center'}`}>
  <div class="glass-card quotes-container">
    {data.title && <h2>{data.title}</h2>}

    <div class="carousel-wrapper">
      <button class="nav-btn right-btn" aria-label="הקודם">&#10094;</button>

      <div class="quotes-track">
        {quotes.map((quote, index) => (
          <div class={`quote-slide ${index === 0 ? 'active' : ''}`} data-index={index}>
            <p class="quote-text">"{quote.text}"</p>
            <p class="quote-author">&mdash; {quote.author}</p>
          </div>
        ))}
      </div>

      <button class="nav-btn left-btn" aria-label="הבא">&#10095;</button>
    </div>

    <div class="pagination-dots">
      {quotes.map((_, index) => (
        <button class={`dot ${index === 0 ? 'active' : ''}`} aria-label={`Quote ${index + 1}`}></button>
      ))}
    </div>
  </div>
</section>

<style>
  /* Base Station Styles */
  .station {
    height: 100dvh;
    width: 100%;
    scroll-snap-align: start;
    display: flex;
    align-items: center;
    padding: 0 10%;
    box-sizing: border-box;
    position: relative;
    z-index: 10;
  }

  .align-start { justify-content: flex-start; }
  .align-end { justify-content: flex-end; }
  .align-center { justify-content: center; text-align: center; }

  /* The Glassmorphism Card */
  .glass-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 16px;
    padding: 3rem;
    max-width: 600px;
    width: 100%;
    color: white;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .station-id {
    font-size: 0.9rem;
    letter-spacing: 2px;
    opacity: 0.7;
    font-weight: 600;
    align-self: flex-start;
  }

  h2 {
    font-size: 2.5rem;
    margin: 0.5rem 0 1.5rem 0;
    line-height: 1.1;
    font-weight: 800;
  }

  /* Carousel Layout */
  .carousel-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: 2.5rem; /* ENLARGED: Pushes the arrows further away from the center */
    min-height: 180px;
  }

  /* CSS GRID SETUP */
  .quotes-track {
    flex-grow: 1;
    display: grid;
    place-items: center;
    touch-action: pan-y; 
    overscroll-behavior-x: none; 
    padding: 0 4rem;
  }

  .quote-slide {
    grid-area: 1 / 1; 
    width: 100%;
    text-align: center;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    
    transition: opacity 0.3s ease, transform 0.3s ease, visibility 0.3s;
  }

  .quote-slide.active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .quote-text {
    font-size: 1.2rem;
    line-height: 1.5;
    font-weight: 400;
    margin: 0 0 1rem 0;
  }

  .quote-author {
    font-size: 1rem;
    opacity: 0.7;
    margin: 0;
    font-weight: 600;
    text-align: left;
  }

  /* Navigation Buttons */
  .nav-btn {
    background: none;
    border: none;
    color: white;
    font-size: 2.8rem; /* ENLARGED: Made the arrows bigger */
    cursor: pointer;
    opacity: 0.6;
    transition: opacity 0.2s, transform 0.2s;
    padding: 0 15px; /* ENLARGED: Gives the arrows more clickable area and space */

    
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    
    -webkit-tap-highlight-color: transparent;
    -webkit-touch-callout: none;
    user-select: none;
    outline: none;
  }

  .right-btn {
    right: 3%; /* Anchors the right arrow to the edge of the station */
  }

  .left-btn {
    left: 3%; /* Anchors the left arrow to the edge of the station */
  }

  
  @media (hover: hover) {
    .nav-btn:hover {
      opacity: 1;
      /* Must include translateY(-50%) to keep it centered while scaling */
      transform: translateY(-50%) scale(1.1);
    }
  }
  

  .nav-btn:active {
    opacity: 1;
    transform: translateY(-50%) scale(0.95);
  }

  /* Pagination Dots */
  .pagination-dots {
    display: flex;
    gap: 8px;
    margin-top: 2rem;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.3);
    border: none;
    cursor: pointer;
    transition: background-color 0.3s, transform 0.3s;
    padding: 0;
  }

  .dot.active {
    background-color: white;
    transform: scale(1.2);
  }

  /* Mobile Overrides */
  @media (max-width: 768px) {
    .station {
      
      padding: 0 5%;
      justify-content: center; 
    }
    .glass-card { padding: 2rem; }
    .quote-text { font-size: 1.2rem; }
    .nav-btn { font-size: 2rem; padding: 0 10px; }
    .carousel-wrapper { gap: 1rem; }
    .quotes-track {
      padding: 0 2rem; 
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const carousels = document.querySelectorAll('.quotes-container');
    
    carousels.forEach(carousel => {
      const slides = carousel.querySelectorAll('.quote-slide');
      const dots = carousel.querySelectorAll('.dot');
      
      const rightBtn = carousel.querySelector('.right-btn'); 
      const leftBtn = carousel.querySelector('.left-btn');  
      
      let currentIndex = 0;
      let isAnimating = false; 
      const FADE_DURATION = 300; 

      // --- TIMESTAMP COOLDOWN (The fix for the stuck trackpad) ---
      let lastActionTime = 0;
      const COOLDOWN_MS = 800; // Ignores extra swipes/momentum for 800ms

      function canInteract() {
        const currentTime = new Date().getTime();
        if (currentTime - lastActionTime > COOLDOWN_MS && !isAnimating) {
          lastActionTime = currentTime;
          return true;
        }
        return false;
      }

      function showSlide(index) {
        if (index === currentIndex) return;
        isAnimating = true;

        let nextIndex = index;
        if (nextIndex < 0) nextIndex = slides.length - 1;
        else if (nextIndex >= slides.length) nextIndex = 0;

        slides[currentIndex].classList.remove('active');
        dots.forEach(d => d.classList.remove('active'));

        setTimeout(() => {
          currentIndex = nextIndex;
          slides[currentIndex].classList.add('active');
          dots[currentIndex].classList.add('active');

          setTimeout(() => {
            isAnimating = false;
          }, FADE_DURATION);

        }, FADE_DURATION); 
      }

      // Buttons
      leftBtn?.addEventListener('click', () => {
        if (canInteract()) showSlide(currentIndex + 1);
      });
      
      rightBtn?.addEventListener('click', () => {
        if (canInteract()) showSlide(currentIndex - 1);
      });
      
      // Dots
      dots.forEach((dot, idx) => {
        dot.addEventListener('click', () => {
          if (canInteract()) showSlide(idx);
        });
      });

      // Mobile Swipe
      let touchStartX = 0;
      let touchStartY = 0;
      
      carousel.addEventListener('touchstart', e => {
        touchStartX = e.touches[0].screenX;
        touchStartY = e.touches[0].screenY;
      }, { passive: true });

      carousel.addEventListener('touchmove', e => {
        if (!touchStartX || !touchStartY) return;

        const deltaX = touchStartX - e.touches[0].screenX;
        const deltaY = touchStartY - e.touches[0].screenY;

        if (Math.abs(deltaX) > Math.abs(deltaY)) {
          e.preventDefault(); // Blocks Chrome "go back" swipe
        }
      }, { passive: false }); 

      carousel.addEventListener('touchend', e => {
        const deltaX = e.changedTouches[0].screenX - touchStartX;
        const deltaY = e.changedTouches[0].screenY - touchStartY;

        if (Math.abs(deltaX) > Math.abs(deltaY)) {
          const swipeThreshold = 50; 
          if (Math.abs(deltaX) > swipeThreshold && canInteract()) {
            if (deltaX > 0) showSlide(currentIndex + 1); 
            else showSlide(currentIndex - 1); 
          }
        }
        touchStartX = 0;
        touchStartY = 0;
      }, { passive: true });

      // Trackpad Swipe
      carousel.addEventListener('wheel', e => {
        if (Math.abs(e.deltaX) > Math.abs(e.deltaY)) {
          e.preventDefault(); // Blocks Chrome trackpad "go back" swipe

          if (Math.abs(e.deltaX) > 20) {
            // Only allows the slide to change if 800ms have passed since the last one
            if (canInteract()) {
              if (e.deltaX > 0) {
                showSlide(currentIndex - 1); 
              } else {
                showSlide(currentIndex + 1); 
              }
            }
          }
        }
      }, { passive: false }); 
    });
  });
</script>