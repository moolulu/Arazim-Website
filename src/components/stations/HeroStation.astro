---
const { data } = Astro.props;
---

<section class="hero-station" data-observer-target>
  <div class="blur-overlay"></div>

  <div class="content-wrapper">
    
    <svg class="animated-border" xmlns="http://www.w3.org/2000/svg">
      <rect 
        class="border-rect" 
        x="3" 
        y="3" 
        width="calc(100% - 6px)" 
        height="calc(100% - 6px)" 
        rx="32" 
        pathLength="100" 
      />
    </svg>

    <div class="text-content">
      <h1>{data.title}</h1>
      <p>{data.text}</p>
    </div>
    
  </div>
</section>

<style>
  .hero-station {
    height: 100dvh;
    width: 100%;
    scroll-snap-align: start; 
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    z-index: 10;
  }

  /* --- 1. The Blur Effect --- */
  .blur-overlay {
    /* FIXED keeps it on the screen while you scroll away */
    position: fixed; 
    inset: 0;
    
    /* 0.1px prevents WebKit/Safari from snapping */
    backdrop-filter: blur(0.1px); 
    -webkit-backdrop-filter: blur(0.1px);
    background: rgba(0, 0, 0, 0);
    
    /* Hide entirely when not in use to save GPU performance */
    visibility: hidden; 
    
    /* Waits 0.8s for the blur to finish before hiding */
    transition: backdrop-filter 0.8s ease, -webkit-backdrop-filter 0.8s ease, background 0.8s ease, visibility 0s linear 0.8s; 
    
    z-index: 1;
    pointer-events: none; 
    will-change: backdrop-filter, background; 
  }

  /* When JS adds the .is-locked class, the blur fades in smoothly */
  .hero-station.is-locked .blur-overlay {
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    background: rgba(0, 0, 0, 0.3); 
    
    /* Show immediately */
    visibility: visible; 
    
    /* No delay on visibility when appearing */
    transition: backdrop-filter 0.8s ease, -webkit-backdrop-filter 0.8s ease, background 0.8s ease, visibility 0s linear 0s; 
  }

  /* --- 2. Layout & Typography --- */
  .content-wrapper {
    position: relative;
    z-index: 2;
    padding: 3rem 4rem;
    transform: translateY(-10%); 
    max-width: 800px;
    text-align: center;
  }

  .text-content {
    position: relative;
    z-index: 3;
    color: white;
  }

  h1 {
    font-size: 5rem;
    margin: 0 0 1rem 0;
    line-height: 1.1;
    font-weight: 800;
  }

  p {
    font-size: 1.5rem;
    line-height: 1.5;
    opacity: 0.9;
    margin: 0;
    font-weight: 300;
  }

  /* --- 3. The Chasing Box Animation --- */
  .animated-border {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 2;
  }

  .border-rect {
    fill: transparent;
    stroke: rgba(255, 255, 255, 0.9);
    stroke-width: 5px; 
    
    /* Since pathLength is 100, we work in percentages from 0 to 100 */
    stroke-dasharray: 0 100;
    stroke-dashoffset: 0;
  }

  .hero-station.is-locked .border-rect {
    /* 12s loop feels very organic */
    animation: caterpillarChase 12s ease-in-out infinite;
  }

  @keyframes caterpillarChase {
    0% {
      /* Start empty at the top */
      stroke-dasharray: 0 100;
      stroke-dashoffset: 0;
    }
    50% {
      /* Head sprinted ahead, tail followed slowly. Circuit is full. */
      stroke-dasharray: 100 0;
      stroke-dashoffset: -50; 
    }
    100% {
      /* Tail sprints to catch the head. Shrunk back to zero. */
      stroke-dasharray: 0 100;
      stroke-dashoffset: -200; 
    }
  }

  @media (max-width: 768px) {
    .content-wrapper { padding: 2rem; }
    h1 { font-size: 3.5rem; }
    p { font-size: 1.2rem; }
  }
</style>

<script>
  const setupObserver = () => {
    const stations = document.querySelectorAll('.hero-station');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-locked');
        } else {
          entry.target.classList.remove('is-locked');
        }
      });
    }, {
      threshold: 0.6 
    });

    stations.forEach(station => observer.observe(station));
  };

  setupObserver();
  document.addEventListener('astro:page-load', setupObserver);
</script>