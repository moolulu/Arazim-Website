---
import { Code } from 'astro:components';
import fs from 'node:fs';
import path from 'node:path';

const { data } = Astro.props;

// Read the files dynamically during Astro's build step
const processedFiles = (data.files || []).map((fileItem, index) => {
  const absolutePath = path.resolve(process.cwd(), fileItem.path);
  let codeContent = '';
  try {
    codeContent = fs.readFileSync(absolutePath, 'utf-8');
  } catch (error) {
    console.error(`CodeStation Error: Could not read file at ${absolutePath}`);
    codeContent = `// Error loading file: ${fileItem.path}\n// Please check the path.`;
  }
  return { ...fileItem, codeContent, isActive: index === 0 };
});
---

<section class={`station align-${data.align}`}>
  <div class="glass-card">
    <h2>{data.title}</h2>
    {data.text && <p>{data.text}</p>}

    <div class="code-widget" dir="ltr">
      
      <div class="tab-header">
        {processedFiles.map((file, index) => (
          <button 
            class={`tab-btn ${file.isActive ? 'active' : ''}`} 
            data-target={`tab-${index}`}
          >
            {file.label}
          </button>
        ))}
        
        <button class="copy-btn" aria-label="Copy code to clipboard">
          <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg class="check-icon hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4a90e2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
      </div>

      <div class="code-scroll-area">
        {processedFiles.map((file, index) => (
          <div class={`code-block ${file.isActive ? '' : 'hidden'}`} data-tab={`tab-${index}`}>
            <Code code={file.codeContent} lang={file.lang} theme="dracula" />
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  /* Base inherited styles */
  .station {
    height: 100dvh;
    width: 100%;
    scroll-snap-align: start;
    display: flex;
    align-items: center;
    padding: 0 10%;
    box-sizing: border-box;
    position: relative;
    z-index: 10;
  }

  .align-start { justify-content: flex-start; } 
  .align-end { justify-content: flex-end; }     
  .align-center { justify-content: center; text-align: center; }

  .glass-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 16px;
    padding: 3rem;
    max-width: 800px; 
    width: 100%;
    box-sizing: border-box;
    color: white;
  }

  .station-id { font-size: 0.9rem; letter-spacing: 2px; opacity: 0.7; font-weight: 600; }
  h2 { font-size: 3.5rem; margin: 0.5rem 0 1rem 0; line-height: 1.1; font-weight: 800; }
  p { font-size: 1.2rem; line-height: 1.6; margin-bottom: 1.5rem; opacity: 0.9; }

  /* --- CODE WIDGET STYLES --- */
  .code-widget {
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 8px;
    overflow: hidden; 
    position: relative;
  }

  .tab-header {
    display: flex;
    background: rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    overflow-x: auto; 
    scrollbar-width: none; /* Hide scrollbar for tabs */
  }

  .tab-btn {
    background: transparent;
    color: rgba(255, 255, 255, 0.6);
    border: none;
    padding: 0.8rem 1.5rem;
    font-family: monospace;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .tab-btn:hover { color: white; background: rgba(255, 255, 255, 0.1); }
  .tab-btn.active { color: #fff; background: rgba(0, 0, 0, 0.3); border-bottom: 2px solid #4a90e2; }

  /* --- NEW: COPY BUTTON STYLES --- */
  .copy-btn {
    margin-left: auto; /* Pushes the button to the far right of the flex container */
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.5);
    padding: 0 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease;
  }

  .copy-btn:hover { color: white; }
  .copy-btn svg { transition: transform 0.2s ease; }
  .copy-btn:active svg { transform: scale(0.9); }
  .hidden { display: none !important; }

  /* Code Container */
  .code-scroll-area {
    max-height: 30vh; 
    overflow-y: auto;
    overflow-x: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.3) transparent;
  }

  .code-block { margin: 0; text-align: left; }
  .code-block :global(pre) {
    margin: 0;
    padding: 1.5rem;
    background-color: transparent !important; 
    font-size: 0.95rem;
    line-height: 1.5;
    font-family: 'Courier New', Courier, monospace;
  }

  @media (max-width: 768px) {
    .station { padding: 0 5%; justify-content: center; }
    .glass-card { padding: 2rem; text-align: right; }
    h2 { font-size: 2.5rem; }
    .code-scroll-area { max-height: 35vh; }
    .code-block :global(pre) { font-size: 0.85rem; padding: 1rem; }
  }
</style>

<script>
  // Vanilla JS scoped to handle toggling and copying for any widget on the page
  const widgets = document.querySelectorAll('.code-widget');

  widgets.forEach(widget => {
    const buttons = widget.querySelectorAll('.tab-btn');
    const blocks = widget.querySelectorAll('.code-block');
    const copyBtn = widget.querySelector('.copy-btn');
    const copyIcon = widget.querySelector('.copy-icon');
    const checkIcon = widget.querySelector('.check-icon');

    // 1. Handle Tab Switching
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('active'));
        blocks.forEach(b => b.classList.add('hidden'));

        btn.classList.add('active');
        const targetId = btn.getAttribute('data-target');
        const targetBlock = widget.querySelector(`.code-block[data-tab="${targetId}"]`);
        
        if (targetBlock) targetBlock.classList.remove('hidden');
      });
    });

    // 2. Handle Copy to Clipboard
    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        // Find whichever code block is currently visible
        const activeBlock = widget.querySelector('.code-block:not(.hidden) pre');
        
        if (activeBlock) {
          try {
            // Copy the raw text content to the clipboard
            await navigator.clipboard.writeText(activeBlock.textContent);
            
            // Swap icons to show success
            copyIcon.classList.add('hidden');
            checkIcon.classList.remove('hidden');
            
            // Swap back after 2 seconds
            setTimeout(() => {
              checkIcon.classList.add('hidden');
              copyIcon.classList.remove('hidden');
            }, 2000);
            
          } catch (err) {
            console.error('Failed to copy code: ', err);
          }
        }
      });
    }
  });
</script>