---
// This assumes the layout passes a 'data' prop to the component
const { data } = Astro.props;
---

<section class="station-container">
  {data.mainTitle && <h2 class="station-main-title">{data.mainTitle}</h2>}
  
  <div class="cards-wrapper">
    {data.cards?.map((card) => (
      <div class="card">
        <div class="card-header">
          <div class="icon-container">
            <img src={card.icon} alt={card.title} />
          </div>
          <h3 class="card-title">{card.title}</h3>
        </div>
        
        <div class="card-body">
          <p class="card-description">{card.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  function setupAccordion() {
    const headers = document.querySelectorAll('.card-header');
    let isAnimating = false; // Prevents clicking rapidly and breaking the animation
    
    headers.forEach(header => {
      header.onclick = (e) => {
        if (isAnimating) return; // Ignore taps if an animation is currently running

        const clickedCard = e.currentTarget.closest('.card');
        const isCurrentlyExpanded = clickedCard.classList.contains('is-expanded');
        const currentlyOpenCard = document.querySelector('.card.is-expanded');
        
        if (currentlyOpenCard && currentlyOpenCard !== clickedCard) {
          // 1. If ANOTHER card is open, close it first
          isAnimating = true;
          currentlyOpenCard.classList.remove('is-expanded');
          
          // 2. Wait for the close animation to finish, then open the new one
          setTimeout(() => {
            clickedCard.classList.add('is-expanded');
            isAnimating = false;
            
            // Smoothly scroll the newly opened card into view so it isn't cut off
            setTimeout(() => {
              clickedCard.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }, 50);
            
          }, 700); 

        } else if (!isCurrentlyExpanded) {
          // If NO cards are open, just open the clicked one immediately
          clickedCard.classList.add('is-expanded');
          
          // Smoothly scroll it into view
          setTimeout(() => {
            clickedCard.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          }, 50);

        } else {
          // If we tapped the already-open card, just close it
          clickedCard.classList.remove('is-expanded');
        }
      };
    });
  }

  setupAccordion();
  document.addEventListener('astro:page-load', setupAccordion);
</script>

<style>
  .station-container {
    height: 100dvh;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem 4rem;
    color: #fff;
    box-sizing: border-box;
  }

  .station-main-title {
    font-size: 2.5rem;
    margin-bottom: 3rem;
    text-align: center;
  }

  .cards-wrapper {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    width: 100%;
    max-width: 1200px;
    margin: auto 0; 
  }

  .card {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 16px;
    padding: 2rem;
    text-align: center;
    backdrop-filter: blur(10px);
    transition: transform 0.3s ease, background 0.3s ease;
  }

  @media (min-width: 861px) {
    .card:hover {
      transform: translateY(-5px);
      background: rgba(255, 255, 255, 0.15);
    }
  }

  .card-header {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .icon-container {
    width: 64px;
    height: 64px;
    margin: 0 auto 1.5rem auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-container img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .card-title {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .card-description {
    font-size: 1.1rem;
    line-height: 1.6;
    opacity: 0.9;
    font-weight: 300;
    margin: 0; 
  }

  /* --- Mobile Layout --- */
  @media (max-width: 860px) {
    .cards-wrapper {
      grid-template-columns: 1fr;
    }
    
    .station-container {
      height: auto;
      min-height: 100dvh;
      padding-top: 4rem;
      padding-bottom: 5rem;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }

    .station-main-title {
      display: none;
    }

    .card {
      padding: 1.5rem;
      -webkit-tap-highlight-color: transparent; 
      display: flex;
      flex-direction: column;
    }

    /* NEW: Highlights the card when it is expanded, matching the desktop hover effect */
    .card.is-expanded {
      background: rgba(255, 255, 255, 0.15);
    }

    .card-header {
      flex-direction: row;
      align-items: center; 
      justify-content: center; 
      gap: 1.2rem;
      cursor: pointer; 
    }

    .icon-container {
      width: 48px;
      height: 48px;
      margin: 0;
      flex-shrink: 0;
    }

    .card-title {
      margin: 0; 
      font-size: 1.5rem; 
      line-height: 1.2;
    }

    .card-description {
      text-align: right; 
    }

    .card-body {
      max-height: 0; 
      overflow: hidden;
      opacity: 0;
      transition: max-height 0.6s ease-in-out, margin-top 0.6s ease-in-out, margin-bottom 0.6s ease-in-out, opacity 0.5s ease-in-out;
    }

    .card.is-expanded .card-body {
      max-height: 500px; 
      margin-top: 1rem; 
      opacity: 1;
    }
  }
</style>