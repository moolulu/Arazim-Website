---
import { sitePages } from '../config.js';

const baseUrl = import.meta.env.BASE_URL;
// Safely remove the trailing slash for building paths
const cleanBaseUrl = baseUrl.endsWith('/') ? baseUrl.slice(0, -1) : baseUrl;
// Logo path fix
const logoPath = cleanBaseUrl + '/logo.png';

// Helper function to perfectly format navigation links
const getNavLink = (path) => {
  if (path === '/') return baseUrl;
  // If it's the home page, just use the base URL
  return cleanBaseUrl + (path.startsWith('/') ? path : '/' + path);
};
---

<header class="site-header">
  <a href={baseUrl} class="brand">
    <img src={logoPath} alt="לוגו ארזים" class="site-logo" width="2034" height="2034"/>
    <div class="logo-group">
      <h1>ארזים</h1>
      <span class="motto">הופכים את הבלתי אפשרי לקשה מאוד</span>
    </div>
  </a>

  <nav class="desktop-nav">
    {sitePages.map(page => (
      <a href={getNavLink(page.path)}>{page.title}</a>
    ))}
  </nav>
</header>

<button id="menu-toggle" class="mobile-menu-btn" aria-expanded="false" aria-controls="mobile-overlay">
  <div class="menu-text-wrapper">
    <span class="text-open">תפריט</span>
    <span class="text-close">סגור</span>
  </div>
  <div class="hamburger">
    <span class="line"></span>
    <span class="line"></span>
    <span class="line"></span>
  </div>
</button>

<div id="mobile-overlay" class="mobile-overlay" aria-hidden="true">
  <nav class="mobile-nav-links">
    {sitePages.map(page => (
      <a href={getNavLink(page.path)} class="mobile-link">{page.title}</a>
    ))}
  </nav>
</div>

<style>
  /* --- Desktop Header Styles --- */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.8rem 1.8rem 1rem 3rem;
    box-sizing: border-box;
    z-index: 1000;
    color: white;
    background: linear-gradient(to bottom, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    color: white;
  }

  .site-logo {
    height: 100px;
    width: auto;
    object-fit: contain;
  }

  .logo-group h1 { 
    margin: 0; 
    font-size: 2.2rem; 
    font-weight: 800; 
    margin-top: -20px;
  }
  
  .motto { 
    font-size: 1rem; 
    opacity: 0.75; 
  }

  .desktop-nav { 
    display: flex; 
    gap: 2.3rem;
    align-items: center;
    margin-top: -48px;
  }
  
  .desktop-nav a {
    color: white;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.2rem;
    transition: opacity 0.3s;
  }
  
  .desktop-nav a:hover { 
    opacity: 0.6; 
  }

  /* --- Base Button Styles --- */
  .mobile-menu-btn {
    display: none;
    background: transparent;
    border: none;
    color: white;
    font-size: 1.2rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    padding: 0.5rem;
    align-items: center; 
    gap: 0.6rem; 
    z-index: 2005; 
  }

  /* --- Smooth Text Transition Styles --- */
  .menu-text-wrapper {
    position: relative;
    width: 48px;
    height: 1.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .text-open, .text-close {
    position: absolute;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .text-open {
    opacity: 1;
    transform: translateY(-1px); 
  }

  .text-close {
    opacity: 0;
    transform: translateY(10px);
  }

  .mobile-menu-btn.is-open .text-open {
    opacity: 0;
    transform: translateY(-10px);
  }

  .mobile-menu-btn.is-open .text-close {
    opacity: 1;
    transform: translateY(-2px);
  }

  /* --- Hamburger Stripes & Animation --- */
  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 18px;
  }

  .hamburger .line {
    display: block;
    width: 100%;
    height: 2px;
    background-color: white;
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }

  .mobile-menu-btn.is-open .hamburger .line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  .mobile-menu-btn.is-open .hamburger .line:nth-child(2) {
    opacity: 0;
  }
  .mobile-menu-btn.is-open .hamburger .line:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  /* --- Mobile Overlay Styles --- */
  .mobile-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100dvh;
    background: rgba(0, 80, 25, 0.65);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    z-index: 2000;
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .mobile-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex-grow: 1;
    gap: 2rem;
  }

  .mobile-link {
    color: white;
    text-decoration: none;
    font-size: 2.5rem;
    font-weight: 800;
  }

  /* --- Mobile Layout Rules --- */
  @media (max-width: 1024px) { 
    .site-header { 
      padding: 0.6rem 0.6rem 1rem 1rem;
    }

    .desktop-nav { 
      display: none; 
    } 
    
    .mobile-menu-btn {
      position: fixed;
      font-size: 1.4rem;
      top: 2.3rem;   /* Adjust this to move it perfectly level with your logo */
      left: 1.5rem;  /* Keeps it pinned to the left side */
      margin: 0;
      padding: 0;
      display: flex;
    }

    .site-logo { 
      height: 75px;
    }
    
    .logo-group h1 { 
      font-size: 2.4rem;
      margin-top: -10px; 
      margin-right: -7px; 
    }
    
    .motto { 
      display: none;
    }
  }
</style>

<script>
  // Helper function to close the menu
  const closeMenu = (overlay, toggleBtn) => {
    overlay.classList.remove('is-open');
    toggleBtn.classList.remove('is-open'); 
    toggleBtn.setAttribute('aria-expanded', 'false');
    overlay.setAttribute('aria-hidden', 'true');
  };

  document.addEventListener('keydown', (e) => {
    const overlay = document.getElementById('mobile-overlay');
    const toggleBtn = document.getElementById('menu-toggle');
    
    if (e.key === 'Escape' && overlay && overlay.classList.contains('is-open')) {
      closeMenu(overlay, toggleBtn);
    }
  });

  document.addEventListener('astro:page-load', () => {
    const toggleBtn = document.getElementById('menu-toggle');
    const overlay = document.getElementById('mobile-overlay');
    const mobileLinks = document.querySelectorAll('.mobile-link');

    if (toggleBtn && overlay) {
      toggleBtn.addEventListener('click', () => {
        if (overlay.classList.contains('is-open')) {
          closeMenu(overlay, toggleBtn);
        } else {
          overlay.classList.add('is-open');
          toggleBtn.classList.add('is-open'); 
          toggleBtn.setAttribute('aria-expanded', 'true');
          overlay.setAttribute('aria-hidden', 'false');
        }
      });
      
      mobileLinks.forEach(link => {
        link.addEventListener('click', () => closeMenu(overlay, toggleBtn));
      });
    }
  });
</script>