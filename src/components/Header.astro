---
import { sitePages } from '../config.js';
import { Image } from 'astro:assets';

const baseUrl = import.meta.env.BASE_URL;

// Safely remove the trailing slash for building paths
const cleanBaseUrl = baseUrl.endsWith('/') ? baseUrl.slice(0, -1) : baseUrl;

// Logo path fix
const logoPath = cleanBaseUrl + '/logo.png';

// Helper function to perfectly format navigation links
const getNavLink = (path) => {
  if (path === '/') return baseUrl; // If it's the home page, just use the base URL
  return cleanBaseUrl + (path.startsWith('/') ? path : '/' + path);
};
---

<header class="site-header">
  <a href={baseUrl} class="brand">
    <img src={logoPath} alt="לוגו ארזים" class="site-logo" width="2034" height="2034"/>
    <div class="logo-group">
      <h1>ארזים</h1>
      <span class="motto">הופכים את הבלתי אפשרי לקשה מאוד</span>
    </div>
  </a>

  <nav class="desktop-nav">
    {sitePages.map(page => (
      <a href={getNavLink(page.path)}>{page.title}</a>
    ))}
  </nav>

  <button id="menu-open" class="mobile-menu-btn">תפריט</button>
</header>

<div id="mobile-overlay" class="mobile-overlay">
  <div class="overlay-header">
    <button id="menu-close" class="close-btn">סגור ✕</button>
  </div>
  <nav class="mobile-nav-links">
    {sitePages.map(page => (
      <a href={getNavLink(page.path)} class="mobile-link">{page.title}</a>
    ))}
  </nav>
</div>

<style>
  /* --- Desktop Header Styles --- */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    /* Changed padding to move it closer to the right edge */
    /* top: 2rem, right: 1.5rem, bottom: 2rem, left: 3rem */
    padding: 1.8rem 1.8rem 1rem 2.4rem;
    box-sizing: border-box;
    z-index: 1000;
    color: white;
    background: linear-gradient(to bottom, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%);
  }

  /* 2. New styles for the logo and text grouping */
  .brand {
    display: flex;
    align-items: center;
    gap: 1rem; /* Space between the image and the text */
    text-decoration: none;
    color: white;
  }

  .site-logo {
    height: 100px; /* Adjust this value to make your logo bigger/smaller */
    width: auto;
    object-fit: contain;
  }

  .logo-group h1 { margin: 0; font-size: 2.2rem; font-weight: 800; margin-top: -20px; }
  .motto { font-size: 1rem;
    opacity: 0.75; }

  .desktop-nav { display: flex; gap: 2.3rem; align-items: center;
  }
  .desktop-nav a {
    color: white;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.2rem;
    transition: opacity 0.3s;
  }
  .desktop-nav a:hover { opacity: 0.6; }

  .mobile-menu-btn {
    display: none;
    background: transparent;
    border: none;
    color: white;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
  }

  /* --- Mobile Overlay Styles --- */
  .mobile-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100dvh;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    z-index: 2000;
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .mobile-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .overlay-header {
    display: flex;
    justify-content: flex-end;
    padding: 2rem 1.5rem;
  }

  .close-btn {
    background: none;
    border: none;
    color: white;
    font-size: 1.2rem;
    font-family: inherit;
    cursor: pointer;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex-grow: 1;
    gap: 2rem;
  }

  .mobile-link {
    color: white;
    text-decoration: none;
    font-size: 2.5rem;
    font-weight: 800;
  }

  /* --- Mobile Layout Rules --- */
  @media (max-width: 768px) {
    .site-header { padding: 1.5rem;
    }
    .desktop-nav { display: none; } 
    .mobile-menu-btn { display: block;
    } 
    
    /* Make the logo slightly smaller on phones so it fits nicely */
    .site-logo { height: 40px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const openBtn = document.getElementById('menu-open');
    const closeBtn = document.getElementById('menu-close');
    const overlay = document.getElementById('mobile-overlay');
    const mobileLinks = document.querySelectorAll('.mobile-link');

    if (openBtn && closeBtn && overlay) {
      openBtn.addEventListener('click', () => {
        overlay.classList.add('is-open');
      });
      
      closeBtn.addEventListener('click', () => {
        overlay.classList.remove('is-open');
      });
   
      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          overlay.classList.remove('is-open');
        });
      });
    }
  });
</script>