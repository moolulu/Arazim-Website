---
import { sitePages } from '../config.js';

const baseUrl = import.meta.env.BASE_URL;
// Safely remove the trailing slash for building paths
const cleanBaseUrl = baseUrl.endsWith('/') ? baseUrl.slice(0, -1) : baseUrl;
// Logo path fix
const logoPath = cleanBaseUrl + '/logo.png';

// Helper function to perfectly format navigation links
const getNavLink = (path) => {
  if (path === '/') return baseUrl;
  // If it's the home page, just use the base URL
  return cleanBaseUrl + (path.startsWith('/') ? path : '/' + path);
};
---

<header class="site-header">
  <a href={baseUrl} class="brand">
    <img src={logoPath} alt="לוגו ארזים" class="site-logo" width="2034" height="2034"/>
    <div class="logo-group">
      <h1>ארזים</h1>
      <span class="motto">הופכים את הבלתי אפשרי לקשה מאוד</span>
    </div>
  </a>

  <nav class="desktop-nav">
    {sitePages.map(page => (
      <a href={getNavLink(page.path)}>{page.title}</a>
    ))}
  </nav>

  <button id="menu-open" class="mobile-menu-btn" aria-expanded="false" aria-controls="mobile-overlay">תפריט</button>
</header>

<div id="mobile-overlay" class="mobile-overlay" aria-hidden="true">
  <div class="overlay-header">
    <button id="menu-close" class="close-btn">סגור ✕</button>
  </div>
  <nav class="mobile-nav-links">
    {sitePages.map(page => (
      <a href={getNavLink(page.path)} class="mobile-link">{page.title}</a>
    ))}
  </nav>
</div>

<style>
  /* --- Desktop Header Styles --- */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center; /* Changed to center for better alignment with the button */
    padding: 1.8rem 1.8rem 1rem 3rem;
    box-sizing: border-box;
    z-index: 1000;
    color: white;
    background: linear-gradient(to bottom, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    color: white;
  }

  .site-logo {
    height: 100px;
    width: auto;
    object-fit: contain;
  }

  .logo-group h1 { 
    margin: 0; 
    font-size: 2.2rem; 
    font-weight: 800; 
    margin-top: -20px;
  }
  .motto { font-size: 1rem; opacity: 0.75; }

  .desktop-nav { 
    display: flex; 
    gap: 2.3rem; 
    align-items: center;
    margin-top: -48px;
  }
  .desktop-nav a {
    color: white;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.2rem;
    transition: opacity 0.3s;
  }
  .desktop-nav a:hover { opacity: 0.6; }

  .mobile-menu-btn {
    display: none;
    background: transparent;
    border: none;
    color: white;
    font-size: 1.2rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    padding: 0.5rem; /* Standardized touch target */
  }

  /* --- Mobile Overlay Styles --- */
  .mobile-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100dvh;
    background: rgba(0, 90, 30, 0.65);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    z-index: 2000;
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .mobile-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .overlay-header {
    display: flex;
    justify-content: flex-end; /* In RTL, this naturally pushes the close button to the left */
    padding: 1.5rem 2.2rem; /* Adjusted to match your desired mobile button placement naturally */
  }

  .close-btn {
    background: none;
    border: none;
    color: white;
    font-size: 1.2rem;
    font-family: inherit;
    cursor: pointer;
    padding: 0.5rem;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex-grow: 1;
    gap: 2rem;
  }

  .mobile-link {
    color: white;
    text-decoration: none;
    font-size: 2.5rem;
    font-weight: 800;
  }

  /* --- Mobile Layout Rules --- */
  @media (max-width: 1024px) { 
    .site-header { 
      padding: 0.6rem 0.6rem 1rem 1rem; 
    }

    .desktop-nav { display: none; } 
    
    /* 1. Remove the overlay header's structural padding so it doesn't get in the way */
    .overlay-header {
      padding: 0;
      height: 0;
    }

    /* 2. Pin BOTH buttons to the exact same viewport coordinates */
    .mobile-menu-btn, .close-btn {
      position: fixed;
      font-size: 1.4rem;
      top: 1.5rem;   /* Distance from top of screen */
      left: 1.2rem;  /* Distance from left of screen */
      width: 80px;   /* Force exact same width */
      height: 40px;  /* Force exact same height */
      margin: 0;
      padding: 0;
      display: flex;
      align-items: center;
      justify-content: center; /* This perfectly centers the text regardless of word length */
      z-index: 2005; /* Ensures both stay above the overlay */
    }

    .site-logo { height: 75px; }
    
    .logo-group h1 { 
      font-size: 2.4rem; 
      margin-top: -10px; 
      margin-right: -7px; 
    }
    .motto { display: none; }
  }
</style>

<script>
  // FIX 2: Attach the document-level event listener OUTSIDE astro:page-load
  // This ensures it only ever attaches once, preventing memory leaks.
  document.addEventListener('keydown', (e) => {
    const overlay = document.getElementById('mobile-overlay');
    const openBtn = document.getElementById('menu-open');
    
    // We check if the overlay exists and is open before acting
    if (e.key === 'Escape' && overlay && overlay.classList.contains('is-open')) {
      overlay.classList.remove('is-open');
      openBtn.setAttribute('aria-expanded', 'false');
      overlay.setAttribute('aria-hidden', 'true');
    }
  });

  document.addEventListener('astro:page-load', () => {
    const openBtn = document.getElementById('menu-open');
    const closeBtn = document.getElementById('menu-close');
    const overlay = document.getElementById('mobile-overlay');
    const mobileLinks = document.querySelectorAll('.mobile-link');

    if (openBtn && closeBtn && overlay) {
      openBtn.addEventListener('click', () => {
        overlay.classList.add('is-open');
        openBtn.setAttribute('aria-expanded', 'true');
        overlay.setAttribute('aria-hidden', 'false');
      });
      
      closeBtn.addEventListener('click', () => {
        overlay.classList.remove('is-open');
        openBtn.setAttribute('aria-expanded', 'false');
        overlay.setAttribute('aria-hidden', 'true');
      });
   
      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          overlay.classList.remove('is-open');
          openBtn.setAttribute('aria-expanded', 'false');
          overlay.setAttribute('aria-hidden', 'true');
        });
      });
    }
  });
</script>