---
// This assumes the layout passes a 'data' prop to the component
const { data } = Astro.props;
---

<section class="station-container">
  {data.mainTitle && <h2 class="station-main-title">{data.mainTitle}</h2>}
  
  <div class="cards-wrapper">
    {data.cards?.map((card) => (
      <div class="card">
        <div class="icon-container">
          <img src={card.icon} alt={card.title} />
        </div>
        <h3 class="card-title">{card.title}</h3>
        <p class="card-description">{card.description}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .station-container {
    height: 100dvh;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem 4rem;
    color: #fff;
    box-sizing: border-box;
  }

  .station-main-title {
    font-size: 2.5rem;
    margin-bottom: 3rem;
    text-align: center;
  }

  .cards-wrapper {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    width: 100%;
    max-width: 1200px;
  }

  .card {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 16px;
    padding: 2rem;
    text-align: center;
    backdrop-filter: blur(10px);
    transition: transform 0.3s ease;
  }

  .card:hover {
    transform: translateY(-5px);
    background: rgba(255, 255, 255, 0.15);
  }

  .icon-container {
    width: 64px;
    height: 64px;
    margin: 0 auto 1.5rem auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Targets the new image tag */
  .icon-container img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    /* Optional: If your SVGs are black and you need them to be white to show up on the dark background, uncomment the line below */
    /* filter: invert(1); */
  }

  .card-title {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .card-description {
    font-size: 1.1rem;
    line-height: 1.6;
    opacity: 0.9;
    font-weight: 300;
  }

  @media (max-width: 860px) {
    .cards-wrapper {
      grid-template-columns: 1fr;
    }
    .station-container {
      height: auto;
      min-height: 100dvh;
      padding-top: 5rem;
      padding-bottom: 5rem;
    }
  }
</style>