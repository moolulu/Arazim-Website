---
import StationPage from '../layouts/Layout.astro';

import backgroundImg from '../assets/images/mountain.jpg';

const stations = [
  {
    type: "hero",
    id: "01",
    title: "שאלות ותשובות",
    text: "תשובות לשאלות הנפוצות ביותר",
  },
  {
    type: "standard",
    title: "מה אם כבר התחלתי תואר?",
    text: "ניתן להגיע עם פטורים לתוכנית במידה ועשיתם עד שלושה רבעים מהתואר.\
    במידה וסיימתם את התואר במלואו, ניתן להתמיין לארזים 2.",
    align: "start" // Will anchor to the Right
  },
  {
    type: "standard",
    title: "מתי מקבלים תשובות קבלה?",
    text: "לרוב בסביבות יוני יש תשובות סופיות. צוות האיתור יפנה אליכם במידה והתקבלתם אז אין צורך לדאוג.",
    align: "start" // Will anchor to the Right
  },
  {
    type: "standard",
    title: "המיונים לארזים מקפיאים מיונים אחרים?",
    text: "לא, המיונים לארזים לא מקפיאים מיונים אחרים.",
    align: "start" // Will anchor to the Right
  },
  {
    type: "standard",
    title: "מה אורך המסלול?",
    text: "שנתיים של תואר, שנתיים שירות סדיר, שלוש שנים קבע.",
    align: "start" // Will anchor to the Right
  },
  {
    type: "standard",
    title: "כמה מתקבלים לארזים כל מחזור?",
    text: "לתוכנית מתקבלים בין 10 ל20 חניכים מידי שנה.",
    align: "start" // Will anchor to the Right
  },
];
---

<StationPage 
  backgroundImage={backgroundImg}
  stations={stations} 
/>