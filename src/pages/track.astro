---
import StationPage from '../layouts/Layout.astro';

import backgroundImg from '../assets/images/road.jpg';

const pageTitle = "המסלול";

const stations = [
  {
    type: "hero",
    id: "00",
    title: "המסלול",
    text: "התחנות המרכזיות במסלול של ארזים",
  },
  {
    id: "01",
    title: "סדנת הכנה לאקדמיה (קיץ 0)",
    text: "במהלך הסדנה מקבלים כלים לקראת הלימודים באקדמיה. הסדנה כוללת קורס אקדמי ראשון, תכנים על ניהול זמנים, עמידה בלחץ, מיומנויות למידה ומסוגלות. בנוסף, במהדלך הסדנה רוכשים בסיס טכנולוגי שישרת את החניכים למשך השנה. במהלך הסדנה מתגבשים חברי המחזור יחד עם הרבה פעילויות חברתיות.",
    align: "start"
  },
  {
    id: "02",
    title: "שנה א'",
    text: "במהלך השנה הראשונה החניכים לוקחים בערך מחצית מכמות הנקודות הנדרשות על מנת להשלים את התואר. בנוסף, החניכים נדרשים ללמוד תכנים מקצועיים אותם התוכנית מספקת, ומקבלים תשומת לב פרטנית עם פגישות אישיות עם מפקד המחזור שלהם. מעבר לכך, החניכים לוקחים חלק בפרוייקטים וחווים עבודה והתנהלות בצוות.",
    align: "end"
  },
  {
    id: "03",
    title: "סדנה מקצועית (קיץ 1)",
    text: "סדנה זו מועברת בבסיס ובמהלכה החניכים עוברים תכנים מסווגים ונחשפים לעשייה המודעינית בצהל. הסדנה היא אינטנסיבית מטבעה ומעבר לחומר המועבר במהלכה, החניכים נבחנים בהתאמה שלהם לשיבוצים השונים של ארזים על מנת להבטיח שיבוץ אופטימלי.",
    align: "start"
  },
  {
    id: "04",
    title: "שנה ב'",
    text: "במהלך השנה השנייה החניכים מסיימים את התואר. מעבר לכך, החניכים לוקחים חלק בסמינר מנהיגות.",
    align: "center"
  },
  {
    id: "05",
    title: "טירונות",
    text: "ארזים עושים טירונות 02.",
    align: "start"
  },
  {
    id: "06",
    title: "סדנת פיקוד (קיץ 2)",
    text: "לפני היציאה לקורס קצינים, החניכים עוברים סדנה מטעם ארזים שמטרתה להכין אותם לקראת הקורס ולהכשיר אותם בפיקוד והובלה.",
    align: "end"
  },
  {
    id: "07",
    title: "קורס קצינים",
    text: "null",
    align: "center"
  },
  {
    id: "08",
    title: "קורס",
    text: "null",
    align: "center"
  },
  {
    id: "09",
    title: "תפקיד",
    text: "null",
    align: "start"
  }
];
---

<StationPage 
  title={pageTitle}
  backgroundImage={backgroundImg}
  stations={stations} 
/>