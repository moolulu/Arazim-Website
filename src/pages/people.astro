---
import StationPage from '../layouts/Layout.astro';
import backgroundImg from '../assets/images/parrot.jpg';

const pageTitle = "האנשים";

const baseUrl = import.meta.env.BASE_URL;
const cleanBaseUrl = baseUrl.endsWith('/') ? baseUrl.slice(0, -1) : baseUrl;

const stations = [
  {
    type: "hero",
    title: "האנשים",
    text: "<תיאור טוב לעמוד>",
  },
  {
  type: "quotes",
  align: "center",
  title: "מפי הבוגרים",
  quotes: [
    { text: "\
החלק האהוב עליי בתוכנית היה החוויה של שנתיים לגור ביחד עם אנשים מבריקים בכל הכיוונים - מקצועית, אקדמית, ואישיותית; מעבר לתואר ולהכשרה של התוכנית שהיינו עושים ביחד, היינו מכינים ביחד ארוחות, מתאמנים, משתתפים ב-CTF-ים, מדברים על מחקרים של מי שעושה תואר שני, הולכים להופעות, ומה לא - השילוב האנושי אפשר את החוויה המשמעותית ביותר\
"
    , author: "סמל נ', בוגר התוכנית" },
    { text: "מילים מילים מילים מילים מילים מילים מילים מילים\
    מילים מילים מילים מילים מילים מילים מילים מילים\
    מילים מילים מילים מילים מילים מילים מילים מילים\
    מילים מילים מילים מילים מילים מילים מילים מילים\
       מילים מילים מילים מילים מילים מילים מילים מילים", author: "בוגר דברן במיוחד" },
    { text: "🥀 וכו'", author: "בוגר אנונימי" }
    ]
  },
  {
    type: "cards",
    "mainTitle": "אחרי הצבא",
    "cards": [
      {
        "icon": cleanBaseUrl + "/jobs/hitech.svg", 
        "title": "הייטק",
        "description": "בין אם בחברות המובילות ובין אם כחלק מסטרטאפ, בוגרי ארזים מוכיחים את עצמם כנכסים בתחומי המחקר והפיתוח."
      },
      {
        "icon": cleanBaseUrl + "/jobs/academia.svg", 
        "title": "אקדמיה",
        "description": "הרבה בוגרים ממשיכים באקדמיה, בין אם לתארים מתקדמים במתמטיקה או מדעי המחשב, ובין אם בהסבה לתחומים אחרים כמו רפואה או מדעי המוח."
      },
      {
        "icon": cleanBaseUrl + "/jobs/army.svg", 
        "title": "קבע",
        "description": "יש בוגרים שממשיכים בצבא בצמרת הפיקודית או כמוקדי ידע בתחומם, וממשיכים לתרום רבות לביטחון המדינה."
      }
    ]
  },
];
---

<StationPage 
  title={pageTitle}
  backgroundImage={backgroundImg}
  stations={stations} 
/>