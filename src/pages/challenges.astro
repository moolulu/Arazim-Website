---
import StationPage from '../layouts/Layout.astro';

import backgroundImg from '../assets/images/flowing paint.jpg';

const stations = [
  {
    type: "hero",
    title: "אתגרים",
    text: "חידות בנושאים מגוונים שארזים עוסקים בהם",
  },
    {
    type: "standard",
    title: "דיסקליימר",
    text: "האתגרים בעמוד הם של חניכים בתוכנית ומטרתם לתת טעימה לדברים שמעניינים אותנו.\
    אין להסיק מכך על אופי המיונים לארזים, והצלחה/חוסר הצלחה באתגרים אינה מנבאת הצלחה/חוסר הצלחה במיונים,\
    ואינה משפיעה את סיכויי הקבלה לתכונית. בפרט, אין לצפות שצוות האיתור יכיר את האתגרים המוצגים כאן.\
    כעת, מקווים שתהנו מהמבחר :)",
    align: "center"
  },
];
---

<StationPage 
  backgroundImage={backgroundImg}
  stations={stations} 
/>