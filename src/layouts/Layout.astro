---
import Header from '../components/Header.astro';
import Station from '../components/Station.astro';
import HeroStation from '../components/HeroStation.astro';
import AxesStation from '../components/AxesStation.astro';
import QuotesStation from '../components/QuotesStation.astro';
import MathStation from '../components/MathStation.astro';
import CodeStation from '../components/CodeStation.astro';

import { getImage } from 'astro:assets';
const { backgroundImage, stations = [], title = 'ארזים' } = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
const faviconPath = baseUrl.endsWith('/') ? 
  baseUrl + 'favicon.png' : baseUrl + '/favicon.png';

// 2. Intercept and optimize the massive background image
const optimizedBg = await getImage({
  src: backgroundImage,
  format: 'webp', // Converts to a fast, modern format
  width: 1920,    // Caps the maximum width to 1920px
});
const bgStyle = `background-image: url('${optimizedBg.src}')`;

// Map the 'type' string from your data to the actual component
const componentMap = {
  standard: Station,
  hero: HeroStation,
  axes: AxesStation,
  quotes: QuotesStation,
  math: MathStation,
  code: CodeStation,
};
---

<html lang="he" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title === "ארזים" ? title : `${title} ● ארזים`}</title>

    <link rel="icon" type="image/png" href={faviconPath} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;600;800&display=swap" rel="stylesheet">
  </head>
  <body>
    <Header />

    <div class="progress-container" aria-hidden="true">
      <div class="progress-bar" id="myBar"></div>
    </div>

    <main class="scroller" id="scroller">
      <div class="scroll-track" style={bgStyle}>
      
        {stations.map((station) => {
          // Resolve the component, defaulting to standard 'Station' if type is missing or unmatched
          const DynamicStation = componentMap[station.type] || Station;
          
          return <DynamicStation data={station} />;
        })}
        
      </div>
    </main>

    <style>
      :global(body, html) {
        margin: 0;
        padding: 0;
        background-color: #000;
        font-family: 'Assistant', system-ui, -apple-system, sans-serif;
      }

      /* The Scroll Snap Container */
      .scroller {
        height: 100dvh;
        overflow-y: scroll;
        scroll-snap-type: y mandatory;
        position: relative;
        scroll-behavior: smooth;
        
        /* HIDE THE NATIVE SCROLLBAR */
        -ms-overflow-style: none;
        scrollbar-width: none;
      }

      /* Hide scrollbar for Chrome, Safari and Opera */
      .scroller::-webkit-scrollbar {
        display: none;
      }

      /* The Scrolling Background Track */
      .scroll-track {
        width: 100%;
        background-size: cover;
        background-position: top center;
        background-repeat: no-repeat;
        /* Darkens the image elegantly so text pops */
        background-color: rgba(0, 0, 0, 0.4);
        background-blend-mode: multiply; 
      }

      /* Progress Spine UI */
      .progress-container {
        position: fixed;
        right: 40px; /* Right side for Hebrew */
        top: 50%;
        transform: translateY(-50%);
        width: 5px;
        height: 50vh;
        background: rgba(255, 255, 255, 0.2);
        z-index: 100;
        border-radius: 10px; /* Rounds the outer track */
        overflow: hidden; /* Keeps the inner bar clipped cleanly */
      }

      .progress-bar {
        width: 100%;
        height: 0%; /* Start at 0 */
        background: #fff;
        border-radius: 10px; /* Stays perfectly round at the bottom */
        /* Note: No transition here, the JS handles the smoothness! */
      }

      @media (max-width: 768px) {
        .progress-container {
          right: 15px;
        }
      }
    </style>

    <script>
      const scroller = document.getElementById('scroller');
      const progressBar = document.getElementById('myBar');

      if (scroller && progressBar) {
        scroller.addEventListener('scroll', () => {
          const scrollHeight = scroller.scrollHeight - scroller.clientHeight;
          
          if (scrollHeight > 0) {
            // Calculate progress as a percentage (0 to 100)
            const scrolled = (scroller.scrollTop / scrollHeight) * 100;
            // Apply it to height
            progressBar.style.height = `${scrolled}%`;
          }
        });
      }
    </script>
  </body>
</html>